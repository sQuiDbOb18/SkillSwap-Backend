# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Authentication
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
PORT=4000
HOST=0.0.0.0

# App settings
APP_NAME=SkillSwap
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:4000
BOOKINGS_PAGE_URL=http://localhost:3000/bookings
SIGN_IN_URL=http://localhost:3000/login
APP_HOME_URL=http://localhost:3000
SUPPORT_EMAIL=support@example.com

# Resend email provider
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_FROM_NAME=SkillSwap
RESEND_REPLY_TO=support@example.com

# Optional template IDs (leave blank to use local templates)
RESEND_TEMPLATE_VERIFICATION_ID=
RESEND_TEMPLATE_EMAIL_CHANGE_ID=
RESEND_TEMPLATE_EMAIL_CHANGE_SUCCESS_ID=
RESEND_TEMPLATE_PASSWORD_RESET_ID=
RESEND_TEMPLATE_PASSWORD_RESET_SUCCESS_ID=
RESEND_TEMPLATE_SWAP_REQUEST_RECEIVED_ID=
RESEND_TEMPLATE_SWAP_REQUEST_ACCEPTED_ID=
RESEND_TEMPLATE_WELCOME_ID=

# Optional email fallback values
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=

# Optional redirect overrides
VERIFY_ACCOUNT_URL=
VERIFY_EMAIL_CHANGE_URL=
RESET_PASSWORD_URL=
VERIFY_ACCOUNT_SUCCESS_URL=
VERIFY_ACCOUNT_FAILURE_URL=
VERIFY_EMAIL_CHANGE_SUCCESS_URL=
VERIFY_EMAIL_CHANGE_FAILURE_URL=
